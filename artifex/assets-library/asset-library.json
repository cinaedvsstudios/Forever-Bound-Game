{
  "schemaVersion": "0.1",
  "libraryId": "artifex-assets-library",
  "name": "Artifex Assets Library",
  "description": "Reusable Artifex and Forever Bound assets indexed for the Scene Editor and future Asset Library.",
  "basePath": "artifex/assets-library/",
  "notes": [
    "animation-frames is currently empty.",
    "animated contains GIF/WebP decorative animated assets.",
    "videos contains MP4 overlay loops intended for screen/lighten/additive style effects.",
    "static-images contains still props, cave assets, character placeholders, and environment objects."
  ],
  "categories": [
    {
      "id": "animated",
      "name": "Animated",
      "path": "animated/",
      "description": "Small animated GIF/WebP overlay, pickup, magic, jewel, and decorative assets."
    },
    {
      "id": "animation-frames",
      "name": "Animation Frames",
      "path": "animation-frames/",
      "description": "Frame-by-frame animation sequences. Currently empty."
    },
    {
      "id": "static-images",
      "name": "Static Images",
      "path": "static-images/",
      "description": "Single still images such as props, cave pieces, characters, and environment objects."
    },
    {
      "id": "videos",
      "name": "Videos",
      "path": "videos/",
      "description": "MP4 visual effect loops. Best used as overlays or blended screen/lighten effects."
    }
  ],
